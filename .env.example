POSTGRES_USER=eventsense
POSTGRES_PASSWORD=eventsense_dev_password
POSTGRES_DB=eventsense_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://eventsense:eventsense_dev_password@postgres:5432/eventsense_ai

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379
REDIS_URL=redis://redis:6379/0
MEMORY_ENABLED=false
SHORT_TERM_MEMORY_TTL_SECONDS=604800
SHORT_TERM_MEMORY_MAX_MESSAGES=10

JWT_SECRET_KEY=change-me-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
# Host port the API is published on (change if 8000 is already taken locally)
API_HOST_PORT=8000

LLM_ENABLED=false
LLM_PROVIDER=gemini
LLM_TIMEOUT_SECONDS=10

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- RAG embeddings (tenant-scoped retrieval over pgvector) ---------------
# Which backend produces document/query embeddings:
#   fallback -> deterministic, NON-SEMANTIC keyword/hash vectors (offline, no key)
#   gemini   -> real semantic embeddings via Gemini (reuses GEMINI_API_KEY)
#   openai   -> real semantic embeddings via OpenAI (reuses OPENAI_API_KEY)
EMBEDDING_PROVIDER=fallback
# Model id for the semantic provider. Empty = provider default
# (gemini: text-embedding-004, openai: text-embedding-3-small).
EMBEDDING_MODEL=
# pgvector column dimension. Must match the embedding model. 768 fits Gemini
# text-embedding-004 and the fallback; OpenAI v3 models are asked to emit it.
# Changing this requires re-running migrations and `make reembed`.
EMBEDDING_DIM=768
# Optional dedicated key. Empty -> reuse GEMINI_API_KEY / OPENAI_API_KEY.
EMBEDDING_API_KEY=
# true: unconfigured/unavailable semantic provider safely degrades to the
# deterministic fallback. false: fail fast at startup if no key is configured.
EMBEDDING_FALLBACK_ENABLED=true
EMBEDDING_TIMEOUT_SECONDS=15
# Minimum cosine similarity for a chunk to count as relevant in SEMANTIC mode.
# Real models have a high similarity floor (e.g. gemini-embedding-001 @768d:
# out-of-domain ~0.45-0.51, in-domain ~0.67-0.73), so 0.6 makes unsupported
# questions refuse cleanly. Lower it if good answers are wrongly refused; raise
# it if unrelated questions slip through. Tune per embedding model.
RAG_SEMANTIC_MIN_SCORE=0.6

INTENT_CLASSIFIER_ARTIFACT_PATH=app/ml/intent_classifier/artifacts/eventsense_tfidf_logreg_baseline.joblib
INTENT_CLASSIFIER_MODEL_VERSION=tfidf-logreg-baseline

# Frontend (Spec 017) — served by the optional frontend container once the app exists
VITE_API_URL=http://localhost:8000

# Frontend (browser) origins allowed to call the API via CORS (comma-separated)
CORS_ALLOW_ORIGINS=http://localhost:5173,http://localhost:4173

# Smoke test (scripts/smoke_test.sh) — seeded demo credentials, safe local placeholders
API_BASE_URL=http://localhost:8000
SMOKE_USER_EMAIL=admin@elegant-weddings.demo
SMOKE_USER_PASSWORD=demo-password-1
SMOKE_TENANT_SLUG=elegant-weddings
